# ==========================================================
# JWT SETTINGS
# ==========================================================
JWT_SECRET=1234567890123456789012345678901234567890123456789012345678901234
JWT_EXPIRATION=86400000

# ==========================================================
# DATABASE SETTINGS (H2)
# ==========================================================
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
H2_CONSOLE_ENABLED=true

# ==========================================================
# SERVICE DISCOVERY
# ==========================================================
EUREKA_SERVER_URL=http://discovery-server:8761/eureka/

# ==========================================================
# CONFIG SERVER
# ==========================================================
CONFIG_SERVER_URL=http://config-server:8888

# ==========================================================
# FRONTEND
# ==========================================================
FRONTEND_URL=http://localhost:5173
# ==========================================================
# DISTRIBUTED TRACING
# ==========================================================
ZIPKIN_URL=http://zipkin:9411
TRACING_SAMPLING_PROBABILITY=1.0

# ==========================================================
# ACTUATOR / MANAGEMENT
# ==========================================================
MANAGEMENT_ENDPOINTS=health,info,env,refresh,metrics,prometheus
HEALTH_SHOW_DETAILS=always
PROMETHEUS_ENABLED=true

# ==========================================================
# LOGGING
# ==========================================================
LOG_LEVEL_ROOT=INFO

# ==========================================================
# GRAFANA
# ==========================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==========================================================
# SERVICE-SPECIFIC H2 DATABASE URLS
# ==========================================================
AUTH_DB_URL=jdbc:h2:file:/data/h2/authdb;DB_CLOSE_ON_EXIT=FALSE
PRODUCT_DB_URL=jdbc:h2:file:/data/h2/productdb;DB_CLOSE_ON_EXIT=FALSE
INVENTORY_DB_URL=jdbc:h2:file:/data/h2/inventorydb;DB_CLOSE_ON_EXIT=FALSE
ORDER_DB_URL=jdbc:h2:file:/data/h2/orderdb;DB_CLOSE_ON_EXIT=FALSE
NOTIFICATION_DB_URL=jdbc:h2:file:/data/h2/notificationdb;DB_CLOSE_ON_EXIT=FALSE

# ==========================================================
# INTER-SERVICE URLS
# ==========================================================
INVENTORY_SERVICE_URL=http://inventory-service:8082